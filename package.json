{
  "name": "ai-hall-of-shame",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:ui": "playwright test --project=ui",
    "test:report": "playwright show-report",
    "dev:setup": "wrangler d1 migrations apply ahos-db --local",
    "cf:setup": "bash scripts/cf-setup.sh",
    "deploy": "pnpm build && npx wrangler pages deploy .svelte-kit/cloudflare --project-name=ahos"
  },
  "dependencies": {
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "dompurify": "^3.3.1",
    "jose": "^6.1.3",
    "marked": "^17.0.3",
    "nanoid": "^5.1.5",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.0",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/dompurify": "^3.2.0",
    "@types/marked": "^6.0.0",
    "svelte": "^5.53.6",
    "svelte-check": "^4.2.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wrangler": "^4.69.0"
  },
  "volta": {
    "node": "24.13.1"
  }
}
