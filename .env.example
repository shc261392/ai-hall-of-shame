# Cloudflare account
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# App secrets (set these on Cloudflare Pages dashboard or via wrangler secret)
JWT_SECRET=

# WebAuthn — must match your deployment domain
# Production: WEBAUTHN_RP_ID=hallofshame.cc  WEBAUTHN_ORIGIN=https://hallofshame.cc
# Local dev:  set in .dev.vars (gitignored) — see .dev.vars.example
WEBAUTHN_RP_ID=
WEBAUTHN_RP_NAME=
WEBAUTHN_ORIGIN=

# Set to "development" in .dev.vars to bypass Cloudflare IP requirements locally
ENVIRONMENT=
WEBAUTHN_RP_ID=hallofshame.cc
WEBAUTHN_RP_NAME=AI Hall of Shame
